{
  "name": "pptautomation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host --port 4173",
    "serve": "npx serve dist --listen 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "postinstall": "node scripts/copy-vendor.mjs",
    "electron:dev": "concurrently -k -s first -n VITE,ELECTRON -c cyan,magenta \"vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:dir": "npm run build && electron-builder --dir"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tldraw/tldraw": "^5.1.0",
    "highlight.js": "^11.11.1",
    "html2canvas": "^1.4.1",
    "jszip": "^3.10.1",
    "mermaid": "^11.15.0",
    "pptxgenjs": "^3.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.9.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "reveal.js": "^6.0.1",
    "unified": "^11.0.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "katex": "^0.17.0",
    "postcss": "^8.4.38",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vite": "^5.3.1",
    "vite-plugin-pwa": "^0.21.0",
    "wait-on": "^9.0.10",
    "workbox-window": "^7.3.0"
  },
  "build": {
    "appId": "com.pptautomation.app",
    "productName": "PPTAuto",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icons/icon-512.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icons/icon-512.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/icons/icon-512.png"
    }
  }
}
